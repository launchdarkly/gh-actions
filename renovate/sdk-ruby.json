{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>launchdarkly/gh-actions//renovate/sdk"],
  "packageRules": [
    {
      "enabled": false,
      "matchDatasources": ["rubygems"]
    },
    {
      "matchPackageNames": ["ruby/setup-ruby"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ]
}
